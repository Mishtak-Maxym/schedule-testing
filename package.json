{
  "name": "schedule-testing-api-tests",
  "version": "1.0.0",
  "private": true,
  "description": "API testing for schedule management system: Postman, Newman, Jest and axios",
  "scripts": {
    "test:api": "jest --runInBand tests/api/*.api.test.js",
    "test:postman": "newman run tests/api/postman/Schedule_API_Tests.postman_collection.json -e tests/api/postman/schedule-local.postman_environment.json",
    "test": "npm run test:api"
  },
  "devDependencies": {
    "axios": "^1.7.9",
    "jest": "^29.7.0",
    "newman": "^6.2.1",
    "pg": "^8.13.1"
  }
}
