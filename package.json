{
  "name": "schedule-testing-api-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Testing project for schedule management system: API, unit and E2E tests",
  "scripts": {
    "test:api": "jest --runInBand tests/api/*.api.test.js",
    "test:postman": "newman run tests/api/postman/Schedule_API_Tests.postman_collection.json -e tests/api/postman/schedule-local.postman_environment.json",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "start:mock-api": "node tests/api/mockScheduleApi.js",
    "start:mock-web": "node tests/e2e/mockWebApp.js",
    "test": "npm run test:api"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "axios": "^1.7.9",
    "jest": "^29.7.0",
    "newman": "^6.2.1",
    "pg": "^8.13.1"
  }
}
